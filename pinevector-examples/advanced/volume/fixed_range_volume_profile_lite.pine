//@version=5
// PineVector Advanced Example: Fixed-Range Volume Profile Lite
// Category: Volume
// Author: PineVector
// Purpose: Educational + portfolio demonstration
// Notes:
// - This script is a reference implementation and may require tuning per market.
// - No performance guarantees. Not financial advice.
indicator("PineVector Fixed-Range VP Lite", overlay=true, max_lines_count=100)

// Inputs
vpGroup = "Volume Profile Settings"
lookback = input.int(200, "Range Bars", minval=50, maxval=1500, group=vpGroup, tooltip="Number of recent bars used for profile calculation.")
bins = input.int(24, "Price Bins", minval=8, maxval=80, group=vpGroup, tooltip="Number of rows used to approximate profile.")
valueAreaPct = input.float(70.0, "Value Area %", minval=50.0, maxval=99.0, step=0.5, group=vpGroup)
showValueAreaBg = input.bool(true, "Highlight Value Area", group=vpGroup)

rangeHigh = ta.highest(high, lookback)
rangeLow = ta.lowest(low, lookback)
rangeSize = math.max(rangeHigh - rangeLow, syminfo.mintick)
step = rangeSize / bins

float totalVol = 0.0
float maxVol = 0.0
int pocIdx = 0

volBins = array.new_float(bins, 0.0)

for i = 0 to lookback - 1
    px = hlc3[i]
    idxRaw = int(math.floor((px - rangeLow) / step))
    idx = math.min(math.max(idxRaw, 0), bins - 1)
    oldVal = array.get(volBins, idx)
    newVal = oldVal + volume[i]
    array.set(volBins, idx, newVal)

for i = 0 to bins - 1
    v = array.get(volBins, i)
    totalVol += v
    if v > maxVol
        maxVol := v
        pocIdx := i

vaTarget = totalVol * (valueAreaPct / 100.0)
vaCum = array.get(volBins, pocIdx)
int lowIdx = pocIdx
int highIdx = pocIdx

while vaCum < vaTarget and (lowIdx > 0 or highIdx < bins - 1)
    leftVol = lowIdx > 0 ? array.get(volBins, lowIdx - 1) : -1.0
    rightVol = highIdx < bins - 1 ? array.get(volBins, highIdx + 1) : -1.0
    if rightVol >= leftVol
        if highIdx < bins - 1
            highIdx += 1
            vaCum += array.get(volBins, highIdx)
        else
            lowIdx -= 1
            vaCum += array.get(volBins, lowIdx)
    else
        if lowIdx > 0
            lowIdx -= 1
            vaCum += array.get(volBins, lowIdx)
        else
            highIdx += 1
            vaCum += array.get(volBins, highIdx)

pocPrice = rangeLow + (pocIdx + 0.5) * step
vah = rangeLow + (highIdx + 1) * step
val = rangeLow + lowIdx * step

plot(pocPrice, "POC", color=color.new(color.orange, 0), linewidth=2)
plot(vah, "VAH", color=color.new(color.green, 0), linewidth=1)
plot(val, "VAL", color=color.new(color.red, 0), linewidth=1)

bgcolor(showValueAreaBg and close <= vah and close >= val ? color.new(color.blue, 92) : na)

var table vpTable = table.new(position.bottom_right, 2, 4, border_width=1)
if barstate.islast
    table.cell(vpTable, 0, 0, "Metric", bgcolor=color.new(color.black, 0), text_color=color.white)
    table.cell(vpTable, 1, 0, "Value", bgcolor=color.new(color.black, 0), text_color=color.white)
    table.cell(vpTable, 0, 1, "POC")
    table.cell(vpTable, 1, 1, str.tostring(pocPrice, format.mintick))
    table.cell(vpTable, 0, 2, "VAH")
    table.cell(vpTable, 1, 2, str.tostring(vah, format.mintick))
    table.cell(vpTable, 0, 3, "VAL")
    table.cell(vpTable, 1, 3, str.tostring(val, format.mintick))
