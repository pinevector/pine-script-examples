//@version=5
indicator("Breakout Signal Indicator", overlay=true)

lookback = input.int(20, "Breakout Lookback", minval=2)
useVolFilter = input.bool(true, "Use Volume Filter")
volLen = input.int(20, "Volume SMA", minval=1)

hh = ta.highest(high[1], lookback)
ll = ta.lowest(low[1], lookback)
volOk = not useVolFilter or volume > ta.sma(volume, volLen)

longBreakout = close > hh and volOk
shortBreakout = close < ll and volOk

plot(hh, "Range High", color=color.new(color.green, 70))
plot(ll, "Range Low", color=color.new(color.red, 70))
plotshape(longBreakout, title="Long Breakout", style=shape.triangleup, location=location.belowbar, color=color.new(color.green, 0), size=size.tiny, text="L")
plotshape(shortBreakout, title="Short Breakout", style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0), size=size.tiny, text="S")
