//@version=5
strategy("EMA Crossover Strategy", overlay=true, initial_capital=10000, pyramiding=0)

fastLen = input.int(20, "Fast EMA", minval=1)
slowLen = input.int(50, "Slow EMA", minval=1)
stopPct = input.float(1.0, "Stop Loss %", minval=0.1, step=0.1) / 100.0
targetPct = input.float(2.0, "Take Profit %", minval=0.1, step=0.1) / 100.0

emaFast = ta.ema(close, fastLen)
emaSlow = ta.ema(close, slowLen)

longEntry = ta.crossover(emaFast, emaSlow)
shortEntry = ta.crossunder(emaFast, emaSlow)

if longEntry
    strategy.entry("Long", strategy.long)
if shortEntry
    strategy.entry("Short", strategy.short)

if strategy.position_size > 0
    longStop = strategy.position_avg_price * (1 - stopPct)
    longTarget = strategy.position_avg_price * (1 + targetPct)
    strategy.exit("Long Exit", "Long", stop=longStop, limit=longTarget)

if strategy.position_size < 0
    shortStop = strategy.position_avg_price * (1 + stopPct)
    shortTarget = strategy.position_avg_price * (1 - targetPct)
    strategy.exit("Short Exit", "Short", stop=shortStop, limit=shortTarget)

plot(emaFast, "Fast EMA", color=color.teal, linewidth=2)
plot(emaSlow, "Slow EMA", color=color.orange, linewidth=2)
plotshape(longEntry, title="Long Entry", style=shape.triangleup, location=location.belowbar, color=color.new(color.green, 0), size=size.tiny)
plotshape(shortEntry, title="Short Entry", style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0), size=size.tiny)
