//@version=5
indicator("Risk Management Module", overlay=false)

accountSize = input.float(10000, "Account Size", minval=100)
riskPct = input.float(1.0, "Risk % Per Trade", minval=0.1, step=0.1)
entryPrice = input.float(100.0, "Entry Price", minval=0.0001)
stopLossPct = input.float(1.0, "Stop Loss %", minval=0.1, step=0.1)
takeProfitPct = input.float(2.0, "Take Profit %", minval=0.1, step=0.1)

riskAmount = accountSize * (riskPct / 100.0)
stopPrice = entryPrice * (1 - stopLossPct / 100.0)
takeProfitPrice = entryPrice * (1 + takeProfitPct / 100.0)
perUnitRisk = math.abs(entryPrice - stopPrice)
positionSize = perUnitRisk > 0 ? riskAmount / perUnitRisk : na

plot(riskAmount, "Risk Amount", color=color.new(color.red, 0))
plot(positionSize, "Position Size", color=color.new(color.green, 0))
plot(stopPrice, "Stop Loss Price", color=color.new(color.orange, 0))
plot(takeProfitPrice, "Take Profit Price", color=color.new(color.blue, 0))
